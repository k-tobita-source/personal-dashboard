{
  "mcpServers": {
    "personal-dashboard": {
      "command": "pnpm",
      "args": ["-F", "@pdash/mcp", "start"]
    },
    "confluence": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "CONFLUENCE_URL": "http://confluence2.fh-all.com",
        "CONFLUENCE_PERSONAL_TOKEN": "${CONFLUENCE_PERSONAL_TOKEN}",
        "READ_ONLY_MODE": "true"
      }
    }
  }
}
