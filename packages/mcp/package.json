{
  "name": "@pdash/mcp",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pdash/api": "workspace:*",
    "@pdash/db": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pdash/eslint-config": "workspace:*",
    "@pdash/prettier-config": "workspace:*",
    "@pdash/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@pdash/prettier-config"
}
